# Server Configuration
PORT=5000
NODE_ENV=development
BACKEND_URL=http://localhost:5000
CLIENT_URL=http://localhost:3000

# Database Configuration (PostgreSQL)
# For Prisma 7, this is used in prisma.config.ts
DATABASE_URL="postgresql://user:password@localhost:5432/ali_mobile_db?schema=public"

# JWT Secrets
JWT_SECRET=your_jwt_access_secret_change_me_in_production
REFRESH_TOKEN_SECRET=your_jwt_refresh_secret_change_me_in_production

# Payment Provider Configuration (Example: AracaPay/AvadaPay)
PAYMENT_PROVIDER_URL=https://api.paymentprovider.com/v1/payments
PAYMENT_API_KEY=your_payment_provider_api_key
PAYMENT_WEBHOOK_SECRET=your_webhook_signing_secret

# n8n Hooks
N8N_ACTIVATION_WEBHOOK_URL=https://your-n8n-instance.com/webhook/activation-notify
